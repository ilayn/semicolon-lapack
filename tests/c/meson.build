# tests/c/meson.build
# Complex single precision test suite

# Build complex single precision test utilities (verification routines)
subdir('testutils')

# Include directories:
#   '..'       -> tests/ (for test_harness.h, test_rng.h)
#   'testutils' -> tests/c/testutils/ (for verify.h)
test_inc_c = include_directories('..', 'testutils')

# =============================================================================
# LAPACK Test Driver Ports (cchk*.f and cdrv*.f)
# Line-by-line translations of the official LAPACK test suite
# =============================================================================

