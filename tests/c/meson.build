foreach name, info : lapack_tests_c
  test(name,
    executable('test_' + name, info[0],
      include_directories: test_inc_c,
      dependencies: [verify_dep_c, cmocka_dep],
    ),
    suite: info[1],
    timeout: 300,
    is_parallel: true,
    env: test_env,
  )
endforeach
